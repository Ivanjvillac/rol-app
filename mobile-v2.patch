From: Claude <noreply@anthropic.com>
Date: Sat, 30 May 2026 09:17:32 +0000
Subject: [PATCH] =?UTF-8?q?feat:=20mejoras=20m=C3=B3vil=20=E2=80=94=20bott?=
 =?UTF-8?q?om=20nav,=20navbar=20slim,=20fix=20iOS,=20investigaci=C3=B3n=20?=
 =?UTF-8?q?apilada?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Bottom nav fija en móvil con 5 destinos (Inicio/Universos/Mesa/Personajes/Perfil)
- Navbar en móvil: solo brand + botón salir, sin links (usan bottom nav)
- Fix altura Mesa en móvil (cuenta navbar 48px + bottom nav 52px + safe-area)
- overscroll-behavior: contain en historial (evita bounce de página en iOS)
- font-size 16px en inputs móvil (evita zoom automático de iOS)
- Panel investigación en móvil: salas como tabs horizontales, pistas abajo

https://claude.ai/code/session_017wsyMPHAc7QUcrZbF1Rcea
---
 src/App.css | 83 ++++++++++++++++++++++++++++++++++++++++++++++++-----
 src/App.jsx | 24 ++++++++++++++++
 2 files changed, 100 insertions(+), 7 deletions(-)

diff --git a/src/App.css b/src/App.css
index e35d17e..78cded9 100644
--- a/src/App.css
+++ b/src/App.css
@@ -1220,16 +1220,17 @@ input, textarea, select {
 
 /* ===== MESA RESPONSIVE ESTILO DISCORD/TELEGRAM ===== */
 @media (max-width: 768px) {
-  /* Navbar */
-  .navbar { height: auto; padding: 0.4rem 0.8rem; flex-wrap: wrap; gap: 0.3rem; }
-  .nav-brand { font-size: 0.9rem; }
-  .nav-links { gap: 0.1rem; overflow-x: auto; flex-wrap: nowrap; }
-  .nav-links button { font-size: 0.68rem; padding: 0.25rem 0.4rem; white-space: nowrap; }
+  /* Navbar: solo brand + salir en móvil */
+  .navbar { height: 48px; padding: 0 1rem; flex-wrap: nowrap; }
+  .nav-brand { font-size: 0.95rem; }
+  .nav-links { gap: 0.2rem; }
+  .nav-links button:not(.btn-cerrar) { display: none; }
+  .btn-cerrar { font-size: 0.8rem; padding: 0.3rem 0.6rem; }
 
   /* Mesa contenedor */
   .mesa {
     flex-direction: column;
-    height: calc(100vh - 80px);
+    height: calc(100vh - 48px - 52px - env(safe-area-inset-bottom, 0px));
     overflow: hidden;
     position: relative;
   }
@@ -1311,7 +1312,13 @@ input, textarea, select {
   }
 
   /* Historial */
-  .historial { padding: 0.7rem; gap: 0.6rem; -webkit-overflow-scrolling: touch; }
+  .historial { padding: 0.7rem; gap: 0.6rem; -webkit-overflow-scrolling: touch; overscroll-behavior: contain; }
+
+  /* Prevenir zoom en iOS al hacer focus en inputs */
+  input, textarea, select { font-size: 16px !important; }
+
+  /* Padding inferior para que el contenido no quede bajo la bottom nav */
+  .page { padding-bottom: calc(52px + env(safe-area-inset-bottom, 0px) + 1rem); }
 
   /* Burbujas compactas */
   .entrada-burbuja { max-width: 92%; min-width: 180px; padding: 0.45rem 0.7rem; }
@@ -3326,3 +3333,65 @@ input, textarea, select {
   .inv-panel { height: 95vh; border-radius: 8px; }
   .inv-salas { width: 140px; }
 }
+
+/* ===== BOTTOM NAV ===== */
+.bottom-nav { display: none; }
+
+@media (max-width: 768px) {
+  .bottom-nav {
+    display: flex;
+    position: fixed;
+    bottom: 0;
+    left: 0;
+    right: 0;
+    z-index: 200;
+    background: var(--bg2);
+    border-top: 1px solid var(--border);
+    padding-bottom: env(safe-area-inset-bottom, 0px);
+  }
+  .bottom-nav button {
+    flex: 1;
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+    gap: 0.15rem;
+    padding: 0.5rem 0.2rem;
+    background: none;
+    border: none;
+    color: var(--text3);
+    cursor: pointer;
+    transition: color 0.15s;
+    min-height: 52px;
+  }
+  .bottom-nav button.active { color: var(--accent); }
+  .bottom-nav button:hover { color: var(--text2); }
+  .bottom-nav-icon { font-size: 1.3rem; line-height: 1; }
+  .bottom-nav-label { font-size: 0.6rem; font-family: 'Cinzel', serif; letter-spacing: 0.03em; text-transform: uppercase; }
+
+  /* El app necesita espacio para no tapar contenido */
+  body { overflow-x: hidden; }
+}
+
+/* ===== INVESTIGACIÓN MOBILE ===== */
+@media (max-width: 640px) {
+  .inv-panel { width: 100vw; height: 100vh; border-radius: 0; }
+  .inv-body { flex-direction: column; }
+  .inv-salas {
+    width: 100%;
+    border-right: none;
+    border-bottom: 1px solid var(--border);
+    flex-direction: row;
+    overflow-x: auto;
+    overflow-y: hidden;
+    flex-wrap: nowrap;
+    max-height: none;
+    -webkit-overflow-scrolling: touch;
+  }
+  .inv-salas-header { flex-shrink: 0; min-width: 70px; }
+  .inv-sala-item { border-bottom: none; border-right: 1px solid color-mix(in srgb, var(--border) 50%, transparent); white-space: nowrap; flex-shrink: 0; min-width: 100px; }
+  .inv-sala-item.activa { border-left: none; border-bottom: 3px solid var(--accent); }
+  .inv-sala-desc { display: none; }
+  .inv-sala-acciones { display: none; }
+  .inv-pistas { flex: 1; min-height: 0; }
+}
diff --git a/src/App.jsx b/src/App.jsx
index a96a2de..3683b03 100644
--- a/src/App.jsx
+++ b/src/App.jsx
@@ -59,6 +59,30 @@ function AppInner({ page, navigate, selectedUniverso, setSelectedUniverso, cerra
       {page === 'personajes' && <Personajes navigate={navigate} selectedUniverso={selectedUniverso} />}
       {page === 'mesa' && <Mesa navigate={navigate} selectedUniverso={selectedUniverso} />}
       {page === 'perfil' && <Perfil userId={userId} userEmail={userEmail} />}
+
+      {/* Barra de navegación inferior — solo móvil */}
+      <nav className="bottom-nav">
+        <button onClick={() => navigate('home')} className={page === 'home' ? 'active' : ''}>
+          <span className="bottom-nav-icon">🏠</span>
+          <span className="bottom-nav-label">Inicio</span>
+        </button>
+        <button onClick={() => navigate('universos')} className={page === 'universos' ? 'active' : ''}>
+          <span className="bottom-nav-icon">🌍</span>
+          <span className="bottom-nav-label">Universos</span>
+        </button>
+        <button onClick={() => navigate('mesa')} className={page === 'mesa' ? 'active' : ''}>
+          <span className="bottom-nav-icon">⚔️</span>
+          <span className="bottom-nav-label">Mesa</span>
+        </button>
+        <button onClick={() => navigate('personajes')} className={page === 'personajes' ? 'active' : ''}>
+          <span className="bottom-nav-icon">👥</span>
+          <span className="bottom-nav-label">Personajes</span>
+        </button>
+        <button onClick={() => navigate('perfil')} className={page === 'perfil' ? 'active' : ''}>
+          <span className="bottom-nav-icon">👤</span>
+          <span className="bottom-nav-label">Perfil</span>
+        </button>
+      </nav>
     </div>
   )
 }
